# Copy this file to .env and fill in your values

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — raises Semantic Scholar rate limit from 1 req/s to 10 req/s
# Get a free key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Used in SSRN User-Agent header (good practice for scrapers)
CONTACT_EMAIL=your@email.com

# Set to 1 to enable SSRN scraping. Disabled by default.
# Note: SSRN has no public API. Scraping may violate their ToS.
ENABLE_SSRN=0

# Cache TTL in hours (default: 24)
RESEARCH_DIGEST_CACHE_TTL_HOURS=24
